---
import { VIBES } from '../config';
---

<section class="vibes section section--dark" aria-label="Brand vibes">
  <div class="container">
    <h2 class="vibes__heading">Brand Vibes</h2>
    <ul class="vibes__list">
      {VIBES.map(({ label, icon }) => (
        <li class="vibes__item">
          <span class="vibes__icon" aria-hidden="true">{icon}</span>
          <span class="vibes__label">{label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .vibes {
    padding: 3rem 0;
  }

  .vibes__heading {
    font-size: 1rem;
    text-align: center;
    margin-bottom: 1.5rem;
    color: var(--teal);
  }

  .vibes__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 2rem;
  }

  .vibes__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .vibes__icon {
    color: var(--orange);
    font-size: 1.1rem;
  }

  .vibes__label {
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
</style>
