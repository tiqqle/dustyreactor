---
import { DISCORD_INVITE_URL, SITE } from '../config';

const year = new Date().getFullYear();
---

<footer class="footer" id="contact">
  <div class="footer__banner">
    <div class="container footer__banner-inner">
      <h2 class="footer__title">Let's build something dusty.</h2>
      <p class="footer__lead">Have an idea? Come hang out on Discord and see what we're working on.</p>
      <a class="btn btn--primary btn--large" href={DISCORD_INVITE_URL} target="_blank" rel="noopener noreferrer">
        Join Discord
      </a>
    </div>
  </div>
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>&copy; {year} {SITE.name}. All rights reserved.</p>
      <a href={DISCORD_INVITE_URL} target="_blank" rel="noopener noreferrer">discord.gg/WTAZQ4kn</a>
    </div>
  </div>
</footer>

<style>
  .footer__banner {
    background: var(--orange);
    color: var(--charcoal);
    padding: 4rem 0;
    text-align: center;
  }

  .footer__banner-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .footer__title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    max-width: 16ch;
  }

  .footer__lead {
    max-width: 32rem;
    font-size: 1.1rem;
    opacity: 0.85;
  }

  .btn--large {
    margin-top: 0.5rem;
    padding: 1rem 2rem;
    font-size: 0.9rem;
  }

  .footer__bottom {
    background: var(--charcoal);
    color: var(--cream);
    padding: 1.25rem 0;
    font-size: 0.85rem;
  }

  .footer__bottom-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    opacity: 0.7;
  }

  .footer__bottom a:hover {
    opacity: 1;
    color: var(--orange);
  }
</style>
