---
import { PILLARS } from '../config';
---

<section class="pillars section--dark" aria-label="What we build">
  <div class="container pillars__inner">
    {PILLARS.map(({ label, icon }) => (
      <div class="pillars__item">
        <span class="pillars__icon" aria-hidden="true">{icon}</span>
        <span class="pillars__label">{label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .pillars {
    padding: 2rem 0;
  }

  .pillars__inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    text-align: center;
  }

  .pillars__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .pillars__icon {
    font-size: 1.75rem;
    line-height: 1;
  }

  .pillars__label {
    font-family: var(--font-display);
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 600px) {
    .pillars__inner {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }
</style>
