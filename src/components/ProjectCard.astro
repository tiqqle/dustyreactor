---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  status: string;
  image: string;
  imageAlt: string;
  imageFit?: 'cover' | 'contain';
  imageBackground?: string;
  link?: {
    href: string;
    label: string;
    external?: boolean;
  };
}

const {
  title,
  subtitle,
  description,
  status,
  image,
  imageAlt,
  imageFit = 'cover',
  imageBackground,
  link,
} = Astro.props;

const mediaStyle = imageBackground ? `--media-bg: ${imageBackground}` : undefined;
---

<article class="project-card">
  <div
    class:list={['project-card__media', imageFit === 'contain' && 'project-card__media--contain']}
    style={mediaStyle}
  >
    <img src={image} alt={imageAlt} width="400" height="280" loading="lazy" />
  </div>
  <div class="project-card__body">
    <span class="status-badge">{status}</span>
    <h3 class="project-card__title">{title}</h3>
    <p class="project-card__subtitle">{subtitle}</p>
    <p class="project-card__desc">{description}</p>
    {link && (
      <a
        class="project-card__link btn btn--secondary"
        href={link.href}
        {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {link.label}
      </a>
    )}
  </div>
</article>

<style>
  .project-card {
    background: var(--cream);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .project-card__media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--beige);
  }

  .project-card__media--contain {
    background: var(--media-bg, var(--cream));
    padding: 1.25rem;
  }

  .project-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-card__media--contain img {
    object-fit: contain;
  }

  .project-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .project-card__title {
    font-size: 1.35rem;
    margin-top: 0.25rem;
  }

  .project-card__subtitle {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--teal);
  }

  .project-card__desc {
    color: var(--brown);
    margin-top: 0.25rem;
  }

  .project-card__link {
    align-self: flex-start;
    margin-top: auto;
    padding-top: 1rem;
    font-size: 0.75rem;
  }
</style>
